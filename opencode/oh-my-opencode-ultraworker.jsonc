{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "ZhiPuGLM-ZWZ/ep-20260212143352-vtb7j",
      "temperature": 0.3,
      "concurrency": 1,
      "description": "主协调器: 最强推理能力, 负责整体规划 (交互式模式)",
      "prompt_append": "你处于 Sisyphus 交互式模式。每个工作步骤完成后，必须询问用户：\n\n1. 是否继续下一步\n2. 是否需要调整当前步骤\n3. 是否需要修改计划\n4. 是否需要添加新的任务\n\n等待用户明确确认后再继续。不要自动推进到下一步。",
      "skills": [
        "superpowers/using-superpowers",
        "superpowers/brainstorming",
        "superpowers/dispatching-parallel-agents",
        "superpowers/verification-before-completion"
      ]
    },
    "sisyphus-ultraworker": {
      "model": "ZhiPuGLM-ZWZ/ep-20260212143352-vtb7j",
      "temperature": 0.3,
      "concurrency": 1,
      "description": "Sisyphus (Ultraworker): 完全自动化模式，不询问用户",
      "prompt_append": "你处于 Sisyphus (Ultraworker) 完全自动化模式。按照 Superpowers 工作流程自动执行所有步骤，不询问用户。只有遇到无法解决的严重错误时才停止并询问用户。\n\n工作流程：\n1. Brainstorming - 探索需求和设计\n2. Writing Plans - 编写实现计划（如果需要）\n3. Subagent-driven Development - 通过子智能体协作实现\n4. Test-driven Development - TDD 开发\n5. Verification - 完成前验证\n6. Code Review - 请求代码审查（如果需要）\n\n自动执行所有步骤，直到任务 100% 完成。",
      "skills": [
        "superpowers/using-superpowers",
        "superpowers/brainstorming",
        "superpowers/dispatching-parallel-agents",
        "superpowers/verification-before-completion",
        "superpowers/subagent-driven-development",
        "superpowers/test-driven-development",
        "superpowers/requesting-code-review"
      ]
    },
    "hephaestus": {
      "model": "opencode/minimax-m2.5-free",
      "variant": "medium",
      "description": "锻造之神: 代码构建与编译专家",
      "skills": [
        "superpowers/using-superpowers",
        "superpowers/subagent-driven-development",
        "superpowers/executing-plans",
        "superpowers/test-driven-development",
        "superpowers/verification-before-completion"
      ]
    },
    "oracle": {
      "model": "ZhiPuGLM-ZWZ/ep-20260212143352-vtb7j",
      "variant": "high",
      "description": "先知: 架构设计专家, 深度分析能力",
      "skills": [
        "superpowers/using-superpowers",
        "superpowers/systematic-debugging"
      ]
    },
    "librarian": {
      "model": "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
      "description": "图书管理员: 代码理解与文档搜索专家",
      "skills": [
        "superpowers/using-superpowers"
      ]
    },
    "explore": {
      "model": "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
      "description": "探索者: 快速响应, 代码库探索",
      "skills": [
        "superpowers/using-superpowers"
      ]
    },
    "multimodal-looker": {
      "model": "ZhiPuGLM-ZWZ/ep-20260212143352-vtb7j",
      "description": "多模态观察者: 图像与多媒体内容分析",
      "skills": [
        "superpowers/using-superpowers"
      ]
    },
    "prometheus": {
      "model": "opencode/trinity-large-preview-free",
      "variant": "max",
      "description": "普罗米修斯: 任务规划与分解专家",
      "skills": [
        "superpowers/using-superpowers",
        "superpowers/writing-plans"
      ]
    },
    "metis": {
      "model": "opencode/trinity-large-preview-free",
      "variant": "max",
      "description": "智慧女神: 需求分析与预规划专家",
      "skills": [
        "superpowers/using-superpowers"
      ]
    },
    "momus": {
      "model": "opencode/trinity-large-preview-free",
      "variant": "medium",
      "description": "批评家: 代码审查与质量保证专家",
      "skills": [
        "superpowers/using-superpowers",
        "superpowers/systematic-debugging",
        "superpowers/test-driven-development"
      ]
    },
    "atlas": {
      "model": "opencode/minimax-m2.5-free",
      "description": "阿特拉斯: 地图绘制与代码结构可视化"
    },
    "document_writer": {
      "model": "opencode/minimax-m2.5-free",
      "description": "文档编写者: 技术文档生成与维护"
    },
    "frontend": {
      "model": "opencode/trinity-large-preview-free",
      "description": "前端开发专家: UI/UX 实现与优化"
    },
    "doc_agent": {
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.7,
      "description": "长文本处理代理: 文档分析与摘要生成"
    },
    "codegen": {
      "model": "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
      "temperature": 0.6,
      "description": "代码生成专用代理: 轻量级代码生成与补全"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
      "description": "视觉工程: 前端、UI/UX、设计、样式、动画",
      "skills": [
        "superpowers/using-superpowers",
        "superpowers/subagent-driven-development"
      ]
    },
    "ultrabrain": {
      "model": "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
      "variant": "high",
      "description": "超级大脑: 逻辑密集型复杂任务, 仅给出目标而非步骤",
      "skills": [
        "superpowers/using-superpowers",
        "superpowers/subagent-driven-development"
      ]
    },
    "deep": {
      "model": "opencode/big-pickle",
      "variant": "medium",
      "description": "深度探索: 目标导向的自主问题解决, 深入理解后行动",
      "skills": [
        "superpowers/using-superpowers",
        "superpowers/subagent-driven-development",
        "superpowers/test-driven-development"
      ]
    },
    "artistry": {
      "model": "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
      "variant": "high",
      "description": "艺术创造: 非常规创造性方法解决复杂问题",
      "skills": [
        "superpowers/using-superpowers",
        "superpowers/brainstorming"
      ]
    },
    "quick": {
      "model": "opencode/gpt-5-nano",
      "description": "快速任务: 简单任务 - 单文件修改、拼写修复、简单变更",
      "skills": [
        "superpowers/using-superpowers"
      ]
    },
    "unspecified-low": {
      "model": "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
      "description": "未分类低耗: 不符合其他类别、低工作量任务",
      "skills": [
        "superpowers/using-superpowers"
      ]
    },
    "unspecified-high": {
      "model": "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
      "variant": "max",
      "description": "未分类高耗: 不符合其他类别、高工作量任务",
      "skills": [
        "superpowers/using-superpowers",
        "superpowers/subagent-driven-development"
      ]
    },
    "writing": {
      "model": "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
      "description": "写作任务: 文档、散文、技术写作",
      "skills": [
        "superpowers/using-superpowers"
      ]
    }
  },
  "defaults": {
    "temperature": 0.5,
    "model": "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
    "fallbackModel": "ZhiPuGLM-ZWZ/ep-20260212143352-vtb7j"
  },
  "concurrency": {
    "globalMax": 5,
    "perModelMax": {
      "opencode/minimax-m2.5-free": 2,
      "opencode/trinity-large-preview-free": 2,
      "opencode/big-pickle": 3,
      "opencode/gpt-5-nano": 2,
      "ZhiPuGLM-CGS/ep-20260212143331-qbknz": 1,
      "ZhiPuGLM-ZWZ/ep-20260212143352-vtb7j": 1
    }
  },
  "plugins": {
    "enabled": [
      "agent-status",
      "model-monitor",
      "task-tracker"
    ],
    "agent-status": {
      "display_mode": "sidebar",
      "show_details": true,
      "refresh_interval": 1000,
      "style": {
        "prefix": "🔹 当前Agent：",
        "color": "cyan",
        "bold": true
      }
    }
  },
  "default_agent": "sisyphus"
}
