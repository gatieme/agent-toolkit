{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "ZhiPuGLM-ZWZ/ep-20260212143352-vtb7j",
      "temperature": 0.3,
      // "maxTokens": 4096,
      "concurrency": 1,
      "description": "主协调器: 最强推理能力, 负责整体规划",
      "skills": [
        "superpowers/using-superpowers",
        "superpowers/brainstorming",
        "superpowers/dispatching-parallel-agents",
        "superpowers/verification-before-completion"
      ]
    },
    "hephaestus": {
      "model": "opencode/kimi-k2.5-free",
      "variant": "medium",
      "description": "锻造之神: 代码构建与编译专家",
      "skills": [
        "superpowers/using-superpowers",
        "superpowers/subagent-driven-development",
        "superpowers/executing-plans",
        "superpowers/test-driven-development",
        "superpowers/verification-before-completion"
      ]
    },
    "oracle": {
      "model": "ZhiPuGLM-ZWZ/ep-20260212143352-vtb7j",
      "variant": "high",
      "description": "先知: 架构设计专家, 深度分析能力",
      "skills": [
        "superpowers/using-superpowers",
        "superpowers/systematic-debugging"
      ]
    },
    "librarian": {
      "model": "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
      "description": "图书管理员: 代码理解与文档搜索专家",
      "skills": [
        "superpowers/using-superpowers"
      ]
    },
    "explore": {
      "model": "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
      "description": "探索者: 快速响应, 代码库探索",
      "skills": [
        "superpowers/using-superpowers"
      ]
    },
    "multimodal-looker": {
      "model": "ZhiPuGLM-ZWZ/ep-20260212143352-vtb7j",
      "description": "多模态观察者: 图像与多媒体内容分析",
      "skills": [
        "superpowers/using-superpowers"
      ]
    }
  },
  "prometheus": {
    "model": "opencode/glm-4.7-free",
    "variant": "max",
    "description": "普罗米修斯: 任务规划与分解专家",
    "skills": [
      "superpowers/using-superpowers",
      "superpowers/writing-plans"
    ]
  },
  "metis": {
    "model": "opencode/glm-4.7-free",
    "variant": "max",
    "description": "智慧女神: 需求分析与预规划专家",
    "skills": [
      "superpowers/using-superpowers"
    ]
  },
    "momus": {
      "model": "opencode/glm-4.7-free",
      "variant": "medium",
      "description": "批评家: 代码审查与质量保证专家",
      "skills": [
        "superpowers/using-superpowers",
        "superpowers/systematic-debugging",
        "superpowers/test-driven-development"
      ]
    },
  "atlas": {
    "model": "opencode/kimi-k2.5-free",
    "description": "阿特拉斯: 地图绘制与代码结构可视化"
  },
  "document_writer": {
    "model": "opencode/kimi-k2.5-free",
    "description": "文档编写者: 技术文档生成与维护"
  },
  // 前端开发
  "frontend": {
    "model": "opencode/glm-4.7-free",
    "description": "前端开发专家: UI/UX 实现与优化"
  },
  "doc_agent": {
    "model": "opencode/kimi-k2.5-free",
    "temperature": 0.7,
    "description": "长文本处理代理: 文档分析与摘要生成",
    //"maxTokens": 8192
  },
  "codegen": {
    "model": "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
    //"model": "opencode/gpt-5-nano",
    "temperature": 0.6,
    //"maxTokens": 2048
    "description": "代码生成专用代理: 轻量级代码生成与补全"
  },
  "categories": {
    "visual-engineering": {
      "model": "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
      "description": "视觉工程: 前端、UI/UX、设计、样式、动画",
      "skills": [
        "superpowers/using-superpowers",
        "superpowers/subagent-driven-development"
      ]
    },
    "ultrabrain": {
      "model": "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
      "variant": "high",
      "description": "超级大脑: 逻辑密集型复杂任务, 仅给出目标而非步骤",
      "skills": [
        "superpowers/using-superpowers",
        "superpowers/subagent-driven-development"
      ]
    },
    "deep": {
      "model": "opencode/big-pickle",
      "variant": "medium",
      "description": "深度探索: 目标导向的自主问题解决, 深入理解后行动",
      "skills": [
        "superpowers/using-superpowers",
        "superpowers/subagent-driven-development",
        "superpowers/test-driven-development"
      ]
    },
    "artistry": {
      "model": "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
      "variant": "high",
      "description": "艺术创造: 非常规创造性方法解决复杂问题",
      "skills": [
        "superpowers/using-superpowers",
        "superpowers/brainstorming"
      ]
    },
    "quick": {
      "model": "opencode/gpt-5-nano",
      "description": "快速任务: 简单任务 - 单文件修改、拼写修复、简单变更",
      "skills": [
        "superpowers/using-superpowers"
      ]
    },
    "unspecified-low": {
      "model": "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
      "description": "未分类低耗: 不符合其他类别、低工作量任务",
      "skills": [
        "superpowers/using-superpowers"
      ]
    },
    "unspecified-high": {
      "model": "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
      "variant": "max",
      "description": "未分类高耗: 不符合其他类别、高工作量任务",
      "skills": [
        "superpowers/using-superpowers",
        "superpowers/subagent-driven-development"
      ]
    },
    "writing": {
      "model": "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
      "description": "写作任务: 文档、散文、技术写作",
      "skills": [
        "superpowers/using-superpowers"
      ]
    }
  },
  "defaults": {
    "temperature": 0.5,
    //"maxTokens": 2048,
    //"model":         "ZhiPuGLM-ZWZ/ep-20260212143352-vtb7j",
    //"fallbackModel": "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
    "model":         "ZhiPuGLM-CGS/ep-20260212143331-qbknz",
    "fallbackModel": "ZhiPuGLM-ZWZ/ep-20260212143352-vtb7j"
  },
  "concurrency": {
    "globalMax": 5,                       // 全局并发控制
    "perModelMax": {
      "opencode/kimi-k2.5-free": 3,
      "opencode/minimax-m2.5-free": 2,
      "opencode/big-pickle": 3,
      "opencode/gpt-5-nano": 2,
      "opencode/trinity-large-preview-free": 2,
      "ZhiPuGLM-CGS/ep-20260212143331-qbknz": 1,
      "ZhiPuGLM-ZWZ/ep-20260212143352-vtb7j": 1
    }
  },
  "plugins": {
    "enabled": [
      "agent-status",  // 核心：启用Agent状态插件
      "model-monitor", // 可选：同时显示当前绑定的模型
      "task-tracker"   // 可选：显示Agent正在执行的任务
    ],
    "agent-status": {
      "display_mode": "sidebar", // 显示位置：sidebar（侧边栏）/terminal（终端提示符）/notification（弹窗）
      "show_details": true,      // 显示详情：Agent ID/版本/当前任务
      "refresh_interval": 1000,  // 刷新频率：1秒（实时）
      "style": {
        "prefix": "🔹 当前Agent：",
        "color": "cyan",         // 终端显示颜色（cyan/red/green/yellow）
        "bold": true
      }
    }
  },
  "default_agent": "Sisyphus (Ultraworker)" // 你的默认Agent
}
